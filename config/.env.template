# AutoPPT Agent Configuration Template
# Copy this file to .env and fill in your API keys

# OpenRouter API Keys (Primary - Fast and Reliable)
OPENROUTER_API_KEY_1=your_openrouter_key_here
OPENROUTER_API_KEY_2=your_second_openrouter_key_here
OPENROUTER_API_KEY_3=your_third_openrouter_key_here

# HuggingFace Tokens (Fallback)
HF_TOKENS=your_hf_token_1,your_hf_token_2,your_hf_token_3

# Optional: Combined format (alternative to numbered keys)
# OPENROUTER_KEYS=key1,key2,key3
# HF_TOKEN=combined_token_string

# Notes:
# - Get OpenRouter keys from: https://openrouter.ai/keys
# - Get HuggingFace tokens from: https://huggingface.co/settings/tokens
# - Multiple keys provide redundancy and load balancing
# - System will automatically rotate keys on failures
