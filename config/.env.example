# API Keys for AutoPPT Agent
# Add your OpenRouter API key here (fast, recommended)
OPENROUTER_KEY=your_openrouter_api_key_here

# Add your HuggingFace API key here (fallback)
HF_TOKEN=your_huggingface_token_here

# You can also add multiple keys separated by commas
# OPENROUTER_KEYS=key1,key2,key3
# HF_TOKENS=token1,token2,token3
