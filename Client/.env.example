# 🧬 Environment Variable Guide (Auto-PPT Agent)
# COPY THIS FILE TO '.env' AND FILL IN YOUR REAL KEYS BEFORE RUNNING THE AGENT.
# THIS FILE SHOULD NEVER BE DELETED, BUT IT SHOULD ONLY CONTAIN DUMMY TEXT.

# 1. Primary LLM keys (OpenRouter - High intelligence for planning)
# You can provide multiple keys separated by commas for built-in rate-limit fallback.
OPENROUTER_KEYS=your_primary_openrouter_key_here,your_secondary_openrouter_key_here

# 2. Fallback LLM tokens (HuggingFace - Redundancy for core research)
# Used if OpenRouter credits run low.
HF_TOKENS=your_huggingface_token_here

# 3. Output Path (Default destination for generated .pptx)
DEFAULT_OUTPUT_FILENAME=Autonomous_Science_Presentation.pptx
